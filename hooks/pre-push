#!/usr/bin/env bash
#
# teammate pre-push hook — blocks direct push to protected branches.
#
# Installed by `teammate init` into .git/hooks/pre-push. Raw bash by design —
# no pre-commit framework dependency, no Python at hook time, no dependency
# install required.
#
# Override mechanism: set TEAMMATE_OVERRIDE=1 in env. Example:
#
#   TEAMMATE_OVERRIDE=1 git push origin main
#
# This is defense-in-depth, not a replacement for GitHub branch protection.
# A determined user can `chmod -x .git/hooks/pre-push` or delete the hook
# entirely. The point is to catch mistakes, not malice.

set -eu

# Configurable. Override by editing this file or setting TEAMMATE_PROTECTED_BRANCHES env.
PROTECTED_BRANCHES_DEFAULT="main master production prod release"
PROTECTED_BRANCHES="${TEAMMATE_PROTECTED_BRANCHES:-$PROTECTED_BRANCHES_DEFAULT}"

if [ "${TEAMMATE_OVERRIDE:-0}" = "1" ]; then
  echo "teammate: TEAMMATE_OVERRIDE=1 set; allowing push." >&2
  exit 0
fi

remote_name="$1"
# shellcheck disable=SC2034   # remote_url unused in v0.1; reserved for future remote-allowlist
remote_url="$2"

# git supplies one or more "<local-ref> <local-sha> <remote-ref> <remote-sha>"
# lines on stdin. We only need <remote-ref> for branch detection.
blocked=0
while read -r _local_ref _local_sha remote_ref _remote_sha; do
  [ -z "$remote_ref" ] && continue
  branch="${remote_ref#refs/heads/}"
  for protected in $PROTECTED_BRANCHES; do
    if [ "$branch" = "$protected" ]; then
      cat <<EOF >&2
teammate: BLOCKED — direct push to protected branch '$branch' on remote '$remote_name'.

The team's policy is to merge to '$branch' through a pull request. If this
push is intentional, override with:

  TEAMMATE_OVERRIDE=1 git push origin $branch

Override is logged in the shell history. Use sparingly.
EOF
      blocked=1
      break
    fi
  done
done

if [ "$blocked" = "1" ]; then
  exit 1
fi

# Also block pushes that include changes to .github/workflows/ files
# alongside other refs. CI pipeline changes deserve a PR review of their own.
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  base=$(git rev-parse "@{u}" 2>/dev/null || echo "")
  if [ -n "$base" ]; then
    workflow_changes=$(git diff --name-only "$base"..HEAD 2>/dev/null | grep -E '^\.github/workflows/.*\.ya?ml$' || true)
    if [ -n "$workflow_changes" ]; then
      cat <<EOF >&2
teammate: WARNING — this push touches CI/CD workflow files:

$workflow_changes

CI/CD pipeline changes carry production blast radius. Make sure this push
goes through code review. To proceed without warning:

  TEAMMATE_OVERRIDE=1 git push ...

EOF
      # Warning, not block. The branch-protection check above handles the hard block.
    fi
  fi
fi

exit 0
